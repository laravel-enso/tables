{
    "name": "laravel-enso/tables",
    "description": "Server-side data tables and export backend for Laravel Enso",
    "keywords": [
        "laravel-enso",
        "datatable",
        "data-table",
        "data-table-server-side"
    ],
    "homepage": "https://github.com/laravel-enso/tables",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Adrian Ocneanu",
            "email": "aocneanu@gmail.com",
            "homepage": "https://laravel-enso.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "openspout/openspout": "^4.0",
        "laravel-enso/enums": "^3.0",
        "laravel-enso/filters": "^3.0",
        "laravel-enso/helpers": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelEnso\\Tables\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelEnso\\Tables\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelEnso\\Tables\\AppServiceProvider"
            ],
            "aliases": []
        }
    }
}
